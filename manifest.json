{
  "manifest_version": 3,
  "name": "SelectSpeak",
  "version": "1.0",
  "description": "Read selected webpage text aloud.",
  "permissions": [
    "tts",
    "contextMenus"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SelectSpeak"
  }
}